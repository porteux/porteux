+bool ObjectInstance::prop_getter_impl(JSContext* cx,
+                                      ObjectPropertyInfoCaller* info_caller,
+                                      JS::CallArgs const& args) {
+    if (!check_gobject_finalized("get any property from")) {
+        args.rval().setUndefined();
+        return true;
+    }
