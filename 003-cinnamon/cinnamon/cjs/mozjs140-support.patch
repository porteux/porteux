+      *inout_length = size;
+    }
+  else
+    {
+      g_free (*array_inout);
+
+      gchar **array_out = g_new0 (gchar *, 2);
+
+      g_assert_nonnull (inout_length);
+      g_assert_nonnull (array_inout);
+
+      array_out[0] = g_strdup ("a");
+      array_out[1] = g_strdup ("b");
+
+      *array_inout = array_out;
+      *inout_length = 2;
+    }
