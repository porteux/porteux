+      break;
+    case SOME_DOUBLE_PROPERTY:
+      self->some_double = g_value_get_double (value);
+      break;
+    case SOME_STRING_PROPERTY:
+      g_clear_pointer (&self->some_string, g_free);
+      self->some_string = g_value_dup_string (value);
+      break;
+    case SOME_STRV_PROPERTY:
