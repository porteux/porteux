+/* Scan /proc/<pid>/maps for every running process and return TRUE if any of
+ * them has libwireplumber-module-logind mapped in.  Much lighter than lsof:
+ * no fork, no pipe, no PATH lookup – just open(2) and read(2) on procfs. */
+static gboolean wireplumber_is_running(void)
+{
+    DIR *proc = opendir("/proc");
+    if (!proc)
+        return FALSE;
+
+    gboolean found = FALSE;
+    struct dirent *entry;
+
+    while (!found && (entry = readdir(proc)) != NULL)
+    {
+        /* Only numeric entries are PIDs. */
+        if (entry->d_name[0] < '1' || entry->d_name[0] > '9')
+            continue;
+
+        char maps_path[64];
+        snprintf(maps_path, sizeof(maps_path), "/proc/%s/maps", entry->d_name);
+
+        FILE *f = fopen(maps_path, "r");
+        if (!f)
+            continue;
+
+        char line[256];
+        while (fgets(line, sizeof(line), f))
+        {
+            if (strstr(line, "libwireplumber-module-logind"))
+            {
+                found = TRUE;
+                break;
+            }
+        }
+        fclose(f);
+    }
+
+    closedir(proc);
+    return found;
+}
+
+static int wait_for_pipewire(void *arg)
+{
+    VolumeALSAPlugin *vol = (VolumeALSAPlugin *)arg;
+
+    int number_attempts = 50;
+    while (number_attempts > 0 && !wireplumber_is_running())
+    {
+        number_attempts--;
+        usleep(200 * 1000);
+    }
+
+    if ( ! asound_initialize(vol))
+    {
+        volumealsa_destructor(vol);
+    }
+
+    return 0;
+}
