#!/bin/bash

PRGNAM=cosmic-icons

CWD=$(dirname "$0")
TMP=$MODULEPATH/$PRGNAM
PKG=$TMP/package

set -e

[ -e $TMP ] && rm -rf $TMP
mkdir -p $TMP $PKG
cd $TMP

git clone https://github.com/pop-os/$PRGNAM
cd $PRGNAM
VERSION=$(git log -1 --date=format:"%Y%m%d" --format="%ad")

just rootdir=$PKG install

# merge with pop-icon-theme
ROOT=./ installpkg $SCRIPTPATH/packages/pop-icon-theme-*.txz
rm usr/share/icons/Pop/*/apps/browser.* # remove this to not mess with our AppStore icon
cp -r $PKG/usr/share/icons/Cosmic/* usr/share/icons/Pop/
rm -fr $PKG/usr/share/icons/Cosmic/*
mv usr/share/icons/Pop/* $PKG/usr/share/icons/Cosmic/

gtk-update-icon-cache $MODULEPATH/$PRGNAM/package/usr/share/icons/Cosmic

mkdir -p $PKG/install
cat $CWD/slack-desc > $PKG/install/slack-desc

echo "Generating icon package. This may take a while..."
cd $MODULEPATH/$PRGNAM/package
makepkg ${MAKEPKGFLAGS} $MODULEPATH/packages/$PRGNAM-$VERSION-${ARCH}-1_porteux.txz > /dev/null 2>&1
