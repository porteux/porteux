From 9723d7b4bdccc45dde1057350eed9a9905f97595 Mon Sep 17 00:00:00 2001
From: Charles Kerr <charles@charleskerr.com>
Date: Thu, 29 Jan 2026 11:45:10 -0600
Subject: [PATCH] fix: crash on fail to update blocklist on GTK when assertions
 are enabled (#8274)

regressed in f8970a9 in 4.1.0-beta.5
---
 gtk/Session.cc | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/gtk/Session.cc b/gtk/Session.cc
index 2658744b006..a06910bd123 100644
--- a/gtk/Session.cc
+++ b/gtk/Session.cc
@@ -1360,7 +1360,7 @@ void Session::blocklist_update()
                 gtr_pref_int_set(TR_KEY_blocklist_date, tr_time());
             }
 
-            impl_->signal_blocklist_updated().emit(*n_rules >= 0);
+            impl_->signal_blocklist_updated().emit(n_rules >= 0);
         });
 }
 
