From: =?UTF-8?q?B=C5=82a=C5=BCej=20Szczygie=C5=82?= <mumei6102@gmail.com>
Date: Sun, 26 Jan 2025 00:51:18 +0100
Subject: [PATCH] compositor: check if 'cwindow_hash' is a valid pointer before
 use

This is NULL when external compositor is used.

Fixes: "g_hash_table_lookup: assertion 'hash_table != NULL' failed"
---
 src/compositor.c | 5 +++++
 1 file changed, 5 insertions(+)

diff --git a/src/compositor.c b/src/compositor.c
index 74fed8731..5641b32c2 100644
--- src/compositor.c
+++ src/compositor.c
@@ -172,6 +172,11 @@ find_cwindow_in_screen (ScreenInfo *screen_info, Window id)
     g_return_val_if_fail (screen_info != NULL, NULL);
     TRACE ("window 0x%lx", id);
 
+    if (!screen_info->cwindow_hash)
+    {
+        return NULL;
+    }
+
     return g_hash_table_lookup(screen_info->cwindow_hash, (gpointer) id);
 }
 
