+static GtkWidget *
+find_first_entry (GtkWidget *widget)
+{
+    if (GTK_IS_ENTRY (widget) && gtk_widget_get_visible (widget))
+        return widget;
+
+    if (GTK_IS_CONTAINER (widget)) {
+        GList *children = gtk_container_get_children (GTK_CONTAINER (widget));
+        for (GList *l = children; l; l = l->next) {
+            GtkWidget *found = find_first_entry (l->data);
+            if (found) {
+                g_list_free (children);
+                return found;
+            }
+        }
+        g_list_free (children);
+    }
+    return NULL;
+}
+
+static gboolean
+focus_password_entry_idle_cb (gpointer user_data)
+{
+    GtkWidget *content = gtk_dialog_get_content_area (GTK_DIALOG (user_data));
+    GtkWidget *entry = find_first_entry (content);
+    if (entry)
+        gtk_widget_grab_focus (entry);
+    return G_SOURCE_REMOVE;
+}
+
+static void
+focus_password_entry_map_cb (GtkWidget *dialog, gpointer user_data)
+{
+    g_idle_add (focus_password_entry_idle_cb, dialog);
+}
